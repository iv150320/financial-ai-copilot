# ── Financial AI Copilot — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.

# ── Application ───────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret-key

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://copilot:copilot@localhost:5432/copilot

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── NVIDIA NIM ────────────────────────────────────────────────────────────
NIM_API_KEY=
NIM_API_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama3-70b-instruct

# ── NIM Gateway (cross-service integration) ───────────────────────────────
NIM_GATEWAY_URL=http://nvidia-nim-gateway:8000

# ── OpenTelemetry ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://observability-platform:4318
OTEL_SERVICE_NAME=financial-ai-copilot

# ── Market Data API ───────────────────────────────────────────────────────
MARKET_DATA_API_URL=https://api.example.com/v1
MARKET_DATA_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api
